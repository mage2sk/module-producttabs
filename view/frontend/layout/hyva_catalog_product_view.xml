<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Override product.info.details with Panth tabs template -->
        <referenceBlock name="product.info.details" template="Panth_ProductTabs::hyva/tabs.phtml">
            <arguments>
                <argument name="panth_config" xsi:type="object">Panth\ProductTabs\ViewModel\Config</argument>
                <argument name="view_model" xsi:type="object">Panth\ProductTabs\ViewModel\Tabs</argument>
            </arguments>
        </referenceBlock>

        <!-- Move reviews INTO the tabs (detailed_info group) -->
        <move element="review_list" destination="product.info.details" after="-"/>
        <move element="product.review.form" destination="product.info.details" after="review_list"/>

        <!-- Add group attribute to reviews so they appear in detailed_info group -->
        <referenceBlock name="review_list">
            <arguments>
                <argument name="group" xsi:type="string">detailed_info</argument>
                <argument name="title" translate="true" xsi:type="string">Reviews</argument>
                <argument name="sort_order" xsi:type="number">30</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
