<?php
/**
 * Panth Product Tabs — Luma template (vanilla JS)
 * Full-featured tabbed UI with sticky nav, deep linking, animations,
 * custom CMS/attribute tabs, configurable labels/visibility/sort order.
 *
 * @var \Magento\Catalog\Block\Product\View\Details $block
 * @var \Magento\Framework\Escaper $escaper
 */

/** @var \Panth\ProductTabs\ViewModel\Config $config */
$config = $block->getData('panth_config');
if (!$config || !$config->isEnabled()) {
    return;
}

/** @var \Panth\ProductTabs\ViewModel\Tabs $viewModel */
$viewModel = $block->getData('view_model');

$detailedInfoGroup = $block->getGroupSortedChildNames('detailed_info', 'getChildHtml');
if (!$detailedInfoGroup) {
    return;
}

$layout = $block->getLayout();
$animationType = $config->getAnimationType();
$mobileBehavior = $config->getMobileBehavior();
$stickyTabs = $config->isStickyTabs();
$lazyLoadReviews = $config->isLazyLoadReviews();
$defaultTabSetting = $config->getDefaultTab();
$tabStyle = $config->getTabStyle();

// Label overrides
$labelMap = [
    'description' => $config->getDescriptionLabel(),
    'additional' => $config->getMoreInfoLabel(),
    'reviews' => $config->getReviewsLabel(),
];

// Visibility settings
$visibilityMap = [
    'description' => $config->showDescription(),
    'additional' => $config->showMoreInfo(),
    'reviews' => $config->showReviews(),
];

// Sort order settings
$sortOrderMap = [
    'description' => $config->getDescriptionOrder(),
    'additional' => $config->getMoreInfoOrder(),
    'reviews' => $config->getReviewsOrder(),
];

// Icons for tab types
$iconMap = [
    'description' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>',
    'additional' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>',
    'reviews' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>',
    'cms' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5"/>',
    'attribute' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125H5.625c-.621 0-1.125-.504-1.125-1.125v-1.5c0-.621.504-1.125 1.125-1.125z"/>',
    'default' => '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>',
];

/**
 * Determine which type a tab alias belongs to
 */
$getTabType = function (string $alias): string {
    if (str_contains($alias, 'description')) {
        return 'description';
    }
    if (str_contains($alias, 'additional') || str_contains($alias, 'more') || str_contains($alias, 'information')) {
        return 'additional';
    }
    if (str_contains($alias, 'review')) {
        return 'reviews';
    }
    return 'other';
};

// Get current product and review count via ViewModel
$product = $viewModel ? $viewModel->getCurrentProduct() : null;
$reviewCount = $viewModel ? $viewModel->getApprovedReviewCount() : 0;

// Build tabs from Magento's detailed_info group
$tabs = [];
foreach ($detailedInfoGroup as $name) {
    $sectionBlock = $layout->getBlock($name);
    if (!$sectionBlock) {
        continue;
    }
    $html = (string) $sectionBlock->toHtml();
    if (empty(trim($html))) {
        continue;
    }
    $alias = $layout->getElementAlias($name);
    $label = $sectionBlock->getData('title');
    if (!$label) {
        $label = $block->getChildData($alias, 'title');
    }
    if (!$label) {
        $label = ucfirst(str_replace(['_', '-', '.'], ' ', $alias));
    }
    if (!$label) {
        continue;
    }

    $tabType = $getTabType($alias);

    // Apply visibility filter
    if ($tabType === 'description' && !$visibilityMap['description']) {
        continue;
    }
    if ($tabType === 'additional' && !$visibilityMap['additional']) {
        continue;
    }
    if ($tabType === 'reviews' && !$visibilityMap['reviews']) {
        continue;
    }

    // Apply label override
    if ($tabType === 'description' && !empty($labelMap['description'])) {
        $label = $labelMap['description'];
    } elseif ($tabType === 'additional' && !empty($labelMap['additional'])) {
        $label = $labelMap['additional'];
    } elseif ($tabType === 'reviews' && !empty($labelMap['reviews'])) {
        $reviewLabel = $labelMap['reviews'];
        $label = $reviewCount > 0 ? $reviewLabel . ' (' . $reviewCount . ')' : $reviewLabel;
    }

    // Determine sort order
    $sortOrder = 50;
    if ($tabType === 'description') {
        $sortOrder = $sortOrderMap['description'];
    } elseif ($tabType === 'additional') {
        $sortOrder = $sortOrderMap['additional'];
    } elseif ($tabType === 'reviews') {
        $sortOrder = $sortOrderMap['reviews'];
    }

    // Icon
    $icon = $iconMap[$tabType] ?? $iconMap['default'];

    $tabs[] = [
        'alias' => $alias,
        'type' => $tabType,
        'label' => $label,
        'html' => $html,
        'icon' => $icon,
        'icon_class' => '',
        'sort_order' => $sortOrder,
        'is_review' => ($tabType === 'reviews'),
    ];
}

// Add Reviews tab if not already present from detailed_info group
$hasReviewTab = false;
foreach ($tabs as $t) {
    if ($t['type'] === 'reviews') {
        $hasReviewTab = true;
        break;
    }
}
if (!$hasReviewTab && $visibilityMap['reviews']) {
    $reviewHtml = '';
    $reviewListBlock = $layout->getBlock('review_list');
    if ($reviewListBlock) {
        $reviewHtml .= $reviewListBlock->toHtml();
    }
    $reviewFormBlock = $layout->getBlock('product.review.form');
    if ($reviewFormBlock) {
        $reviewHtml .= $reviewFormBlock->toHtml();
    }
    if (!empty(trim($reviewHtml))) {
        $reviewLabel = $labelMap['reviews'] ?: 'Reviews';
        $tabs[] = [
            'alias' => 'reviews',
            'type' => 'reviews',
            'label' => $reviewCount > 0 ? $reviewLabel . ' (' . $reviewCount . ')' : $reviewLabel,
            'html' => $reviewHtml,
            'icon' => $iconMap['reviews'],
            'icon_class' => '',
            'sort_order' => $sortOrderMap['reviews'],
            'is_review' => true,
        ];
    }
}

// Add custom CMS block tabs
$customCmsTabs = $config->getCustomCmsTabs();
if (!empty($customCmsTabs)) {
    foreach ($customCmsTabs as $cmsTab) {
        if (empty($cmsTab['enabled']) || $cmsTab['enabled'] === '0') {
            continue;
        }
        if (empty($cmsTab['title']) || empty($cmsTab['block_identifier'])) {
            continue;
        }
        try {
            $cmsHtml = $block->getLayout()
                ->createBlock(\Magento\Cms\Block\Block::class)
                ->setBlockId(trim($cmsTab['block_identifier']))
                ->toHtml();
        } catch (\Exception $e) {
            $cmsHtml = '';
        }
        if (empty(trim($cmsHtml))) {
            continue;
        }
        $cmsAlias = 'cms_' . preg_replace('/[^a-z0-9_]/', '_', strtolower(trim($cmsTab['block_identifier'])));
        $tabs[] = [
            'alias' => $cmsAlias,
            'type' => 'cms',
            'label' => $cmsTab['title'],
            'html' => $cmsHtml,
            'icon' => $iconMap['cms'],
            'icon_class' => trim($cmsTab['icon_class'] ?? ''),
            'sort_order' => (int) ($cmsTab['sort_order'] ?? 100),
            'is_review' => false,
        ];
    }
}

// Add custom attribute tabs
$customAttributeTabs = $config->getCustomAttributeTabs();
if (!empty($customAttributeTabs) && isset($product) && $product) {
    foreach ($customAttributeTabs as $attrTab) {
        if (empty($attrTab['enabled']) || $attrTab['enabled'] === '0') {
            continue;
        }
        if (empty($attrTab['title']) || empty($attrTab['attribute_codes'])) {
            continue;
        }
        $attrCodes = array_map('trim', explode(',', $attrTab['attribute_codes']));
        $attrRows = [];
        foreach ($attrCodes as $code) {
            if (empty($code)) {
                continue;
            }
            $attribute = $product->getResource()->getAttribute($code);
            if (!$attribute) {
                continue;
            }
            $attrLabel = $attribute->getStoreLabel();
            $attrValue = $attribute->getFrontend()->getValue($product);
            if ($attrValue === null || $attrValue === '' || $attrValue === false || $attrValue === 'No' || $attrValue === 'N/A') {
                continue;
            }
            $attrRows[] = [
                'label' => $attrLabel,
                'value' => $attrValue,
            ];
        }
        if (empty($attrRows)) {
            continue;
        }
        // Build table HTML
        $attrHtml = '<table class="panth-attr-table"><tbody>';
        foreach ($attrRows as $row) {
            $attrHtml .= '<tr><td>' . $escaper->escapeHtml($row['label']) . '</td>'
                . '<td>' . $escaper->escapeHtml($row['value']) . '</td></tr>';
        }
        $attrHtml .= '</tbody></table>';

        $attrAlias = 'attr_' . preg_replace('/[^a-z0-9_]/', '_', strtolower(trim($attrTab['title'])));
        $tabs[] = [
            'alias' => $attrAlias,
            'type' => 'attribute',
            'label' => $attrTab['title'],
            'html' => $attrHtml,
            'icon' => $iconMap['attribute'],
            'icon_class' => trim($attrTab['icon_class'] ?? ''),
            'sort_order' => (int) ($attrTab['sort_order'] ?? 100),
            'is_review' => false,
        ];
    }
}

// Sort tabs by sort_order
usort($tabs, function ($a, $b) {
    return $a['sort_order'] <=> $b['sort_order'];
});

// Re-index
foreach ($tabs as $i => &$tab) {
    $tab['index'] = $i;
}
unset($tab);

if (empty($tabs)) {
    return;
}

// Determine default active tab index
$defaultActiveTab = 0;
if ($defaultTabSetting === 'first') {
    $defaultActiveTab = 0;
} else {
    $typeMap = [
        'description' => 'description',
        'more_info' => 'additional',
        'reviews' => 'reviews',
    ];
    $targetType = $typeMap[$defaultTabSetting] ?? null;
    if ($targetType) {
        foreach ($tabs as $tab) {
            if ($tab['type'] === $targetType) {
                $defaultActiveTab = $tab['index'];
                break;
            }
        }
    }
}

// Build alias-to-index map for deep linking
$aliasIndexMap = [];
foreach ($tabs as $tab) {
    $aliasIndexMap[$tab['alias']] = $tab['index'];
    // Also map by type for convenience
    if ($tab['type'] === 'description') {
        $aliasIndexMap['description'] = $tab['index'];
    }
    if ($tab['type'] === 'additional') {
        $aliasIndexMap['more-information'] = $tab['index'];
        $aliasIndexMap['more_info'] = $tab['index'];
    }
    if ($tab['type'] === 'reviews') {
        $aliasIndexMap['reviews'] = $tab['index'];
    }
}
$aliasIndexMapJson = json_encode($aliasIndexMap);

// Build index-to-alias map for URL hash updates
$indexAliasMap = [];
foreach ($tabs as $tab) {
    if ($tab['type'] === 'description') {
        $indexAliasMap[$tab['index']] = 'description';
    } elseif ($tab['type'] === 'additional') {
        $indexAliasMap[$tab['index']] = 'more-information';
    } elseif ($tab['type'] === 'reviews') {
        $indexAliasMap[$tab['index']] = 'reviews';
    } else {
        $indexAliasMap[$tab['index']] = $tab['alias'];
    }
}
$indexAliasMapJson = json_encode($indexAliasMap);

// Determine which tab index is reviews for lazy load
$reviewsTabIndex = -1;
foreach ($tabs as $tab) {
    if ($tab['is_review']) {
        $reviewsTabIndex = $tab['index'];
        break;
    }
}

$isVertical = ($tabStyle === 'vertical');
$isScrollMobile = ($mobileBehavior === 'scroll');
?>

<div class="product info detailed panth-tabs"
     id="panth-product-tabs">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous">
