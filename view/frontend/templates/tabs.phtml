    <?php if ($stickyTabs): ?></div><?php endif; ?>

<?php if ($isVertical): ?>
    <div class="panth-tabs__content">
<?php endif; ?>

    <!-- Tab Panels -->
    <?php foreach ($tabs as $tab): ?>

    <!-- Mobile Accordion Header -->
    <button type="button"
