            <?php if (!empty($tab['icon_class'])): ?>
                <i class="bi <?= $escaper->escapeHtmlAttr($tab['icon_class']) ?>" style="font-size:16px;"></i>
            <?php else: ?>
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <?= /* @noEscape */ $tab['icon'] ?>
                </svg>
            <?php endif; ?>
            <?= $escaper->escapeHtml($tab['label']) ?>
        </button>
        <?php endforeach; ?>
