    </div><!-- /.panth-tabs__wrapper -->
<?php endif; ?>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';

    var container = document.getElementById('panth-product-tabs');
    if (!container) return;

    var animation = <?= /* @noEscape */ json_encode($animationType) ?>;
    var defaultActiveTab = <?= (int) $defaultActiveTab ?>;
    var aliasMap = <?= /* @noEscape */ $aliasIndexMapJson ?>;
    var indexAliasMap = <?= /* @noEscape */ $indexAliasMapJson ?>;
    var reviewsTabIndex = <?= (int) $reviewsTabIndex ?>;
    var lazyLoadReviews = <?= $lazyLoadReviews ? 'true' : 'false' ?>;
    var reviewsLoaded = !lazyLoadReviews;
    var activeTab = defaultActiveTab;

    var tabBtns = container.querySelectorAll('.panth-tabs__btn');
    var accBtns = container.querySelectorAll('.panth-tabs__acc-btn');
    var panels = container.querySelectorAll('.panth-tabs__panel');
    var mobileBreakpoint = 768;

    function isMobile() {
        return window.innerWidth < mobileBreakpoint;
    }

    function showPanel(panel, anim) {
        if (anim === 'fade') {
            panel.classList.add('panth-tabs__panel--active', 'panth-tab-fade-enter');
            // Force reflow
            panel.offsetHeight;
            panel.classList.remove('panth-tab-fade-enter');
            panel.classList.add('panth-tab-fade-active');
            var onEnd = function() {
                panel.removeEventListener('transitionend', onEnd);
                panel.classList.remove('panth-tab-fade-active');
            };
            panel.addEventListener('transitionend', onEnd);
        } else if (anim === 'slide') {
            panel.classList.add('panth-tabs__panel--active', 'panth-tab-slide-enter');
            // Force reflow
            panel.offsetHeight;
            panel.classList.remove('panth-tab-slide-enter');
            panel.classList.add('panth-tab-slide-active');
            var onEnd = function() {
                panel.removeEventListener('transitionend', onEnd);
                panel.classList.remove('panth-tab-slide-active');
            };
            panel.addEventListener('transitionend', onEnd);
        } else {
            panel.classList.add('panth-tabs__panel--active');
        }
    }

    function hidePanel(panel, anim) {
        if (anim === 'fade') {
            panel.classList.add('panth-tab-fade-leave');
            var onEnd = function() {
                panel.removeEventListener('transitionend', onEnd);
                panel.classList.remove('panth-tabs__panel--active', 'panth-tab-fade-leave');
            };
            panel.addEventListener('transitionend', onEnd);
        } else if (anim === 'slide') {
            panel.classList.add('panth-tab-slide-leave');
            var onEnd = function() {
                panel.removeEventListener('transitionend', onEnd);
                panel.classList.remove('panth-tabs__panel--active', 'panth-tab-slide-leave');
            };
            panel.addEventListener('transitionend', onEnd);
        } else {
            panel.classList.remove('panth-tabs__panel--active');
        }
    }

    function setTab(index) {
        if (index === activeTab && isMobile()) {
            // Toggle off on mobile accordion
            activeTab = -1;
            panels.forEach(function(p) {
                if (p.classList.contains('panth-tabs__panel--active')) {
                    hidePanel(p, 'slide');
                }
            });
            accBtns.forEach(function(b) {
                b.classList.remove('panth-tabs__acc-btn--active');
            });
            return;
        }

        var prevTab = activeTab;
        activeTab = index;

        // Update tab buttons
        tabBtns.forEach(function(btn) {
            var btnIndex = parseInt(btn.getAttribute('data-panth-tab-index'), 10);
            if (btnIndex === index) {
                btn.classList.add('panth-tabs__btn--active');
                btn.setAttribute('aria-selected', 'true');
            } else {
                btn.classList.remove('panth-tabs__btn--active');
                btn.setAttribute('aria-selected', 'false');
            }
        });

        // Update accordion buttons
        accBtns.forEach(function(btn) {
            var btnIndex = parseInt(btn.getAttribute('data-panth-acc-index'), 10);
            if (btnIndex === index) {
                btn.classList.add('panth-tabs__acc-btn--active');
            } else {
                btn.classList.remove('panth-tabs__acc-btn--active');
            }
        });

        // Hide all active panels, show the target
        var animToUse = isMobile() ? 'slide' : animation;
        var delay = animToUse === 'none' ? 0 : 180;

        panels.forEach(function(p) {
            var pIndex = parseInt(p.getAttribute('data-panth-panel-index'), 10);
            if (pIndex !== index && p.classList.contains('panth-tabs__panel--active')) {
                hidePanel(p, animToUse);
            }
        });

        setTimeout(function() {
            panels.forEach(function(p) {
                var pIndex = parseInt(p.getAttribute('data-panth-panel-index'), 10);
                if (pIndex === index) {
                    showPanel(p, animToUse);
                }
            });
        }, delay);

        // Update URL hash
        if (index >= 0 && indexAliasMap.hasOwnProperty(index)) {
            history.replaceState(null, null, '#' + indexAliasMap[index]);
        }

        // Lazy load reviews
        if (lazyLoadReviews && index === reviewsTabIndex && !reviewsLoaded) {
            setTimeout(function() {
                reviewsLoaded = true;
                var reviewPanel = container.querySelector('.panth-tabs__panel[data-panth-lazy-review="1"]');
                if (reviewPanel) {
                    var spinner = reviewPanel.querySelector('.panth-tabs__review-spinner');
                    var content = reviewPanel.querySelector('.panth-tabs__review-content');
                    if (spinner) spinner.style.display = 'none';
                    if (content) content.style.display = '';
                }
            }, 300);
        }
    }

    // Tab button click
    tabBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            var index = parseInt(btn.getAttribute('data-panth-tab-index'), 10);
            setTab(index);
        });
    });

    // Accordion button click
    accBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            var index = parseInt(btn.getAttribute('data-panth-acc-index'), 10);
            setTab(index);
        });
    });

    // Deep link: check URL hash on load
    var hash = window.location.hash.replace('#', '');
    if (hash && aliasMap.hasOwnProperty(hash)) {
        setTab(aliasMap[hash]);
    }

    // Listen for hash changes
    window.addEventListener('hashchange', function() {
        var hash = window.location.hash.replace('#', '');
        if (hash && aliasMap.hasOwnProperty(hash)) {
            setTab(aliasMap[hash]);
        }
    });

    // Expose for external use (e.g., "Write a Review" links)
    window.panthTabs = { setTab: setTab };
});
</script>
<?php if ($stickyTabs): ?>
<script>
(function() {
    function setStickyTop() {
        var wrap = document.getElementById('panth-sticky-nav-wrap');
        if (!wrap) return;
        var top = 0;
        var selectors = ['.page-header', '.header-main', 'header', '.header.content'];
        for (var i = 0; i < selectors.length; i++) {
            var el = document.querySelector(selectors[i]);
            if (el) {
                var styles = window.getComputedStyle(el);
                var pos = styles.position;
                if (pos === 'sticky' || pos === 'fixed') {
                    top = Math.max(top, el.offsetHeight);
                }
            }
        }
        if (top === 0) {
            var ph = document.querySelector('.page-header');
            if (ph) top = ph.offsetHeight;
        }
        wrap.style.top = top + 'px';
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setStickyTop);
    } else {
        setStickyTop();
    }
    window.addEventListener('resize', setStickyTop);
    setTimeout(setStickyTop, 1000);
})();
</script>
<?php endif; ?>
