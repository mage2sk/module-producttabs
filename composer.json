{
  "name": "mage2kishan/module-producttabs",
  "description": "Product detail page tab customization for Magento 2. Supports horizontal/vertical tab styles, fade/slide/none animations, and mobile accordion. Compatible with Hyva and Luma themes.",
  "type": "magento2-module",
  "version": "1.0.1",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "magento/framework": "^103.0",
    "magento/module-catalog": "^104.0",
    "magento/module-store": "^101.0",
    "magento/module-widget": "^101.0",
    "magento/module-backend": "^102.0",
    "mage2kishan/module-core": "^1.0"
  },
  "suggest": {
    "hyva-themes/magento2-default-theme": "Required for Hyva theme support with Alpine.js tabs"
  },
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "Panth\\ProductTabs\\": ""
    }
  },
  "keywords": [
    "magento2",
    "hyva",
    "product-tabs"
  ],
  "authors": [
    {
      "name": "Kishan Savaliya",
      "email": "kishansavaliyakb@gmail.com",
      "homepage": "https://kishansavaliya.com"
    }
  ],
  "extra": {
    "map": [
      [
        "*",
        "Panth/ProductTabs"
      ]
    ]
  }
}
